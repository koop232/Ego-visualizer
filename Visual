-- Tile builder (movable tile + image + name + price)
local function createTile(opts)
	-- opts: {Name, ImageId, PriceText, StartPos}
	local tile = Instance.new("Frame")
	tile.Name = opts.Name .. "_Tile"
	tile.Size = UDim2.new(0, 120, 0, 140)
	tile.Position = opts.StartPos or UDim2.new(0, 0, 0, 0)
	tile.BackgroundColor3 = Color3.fromRGB(20,20,20)
	tile.BorderSizePixel = 0
	tile.Parent = area
	Instance.new("UICorner", tile).CornerRadius = UDim.new(0, 12)

	local stroke = Instance.new("UIStroke", tile)
	stroke.Thickness = 2
	stroke.Color = Color3.fromRGB(80,80,80)
	stroke.Transparency = 0.25

	-- Image
	local img = Instance.new("ImageLabel")
	img.Name = "Icon"
	img.Size = UDim2.new(1, -16, 0, 86)
	img.Position = UDim2.new(0, 8, 0, 8)
	img.BackgroundTransparency = 1
	img.ScaleType = Enum.ScaleType.Fit
	img.Image = "rbxassetid://" .. tostring(opts.ImageId)
	img.Parent = tile

	-- Name (also helps if image doesn't load)
	local name = Instance.new("TextLabel")
	name.Name = "Name"
	name.Size = UDim2.new(1, -12, 0, 18)
	name.Position = UDim2.new(0, 6, 0, 96)
	name.BackgroundTransparency = 1
	name.Text = opts.Name
	name.Font = Enum.Font.GothamBold
	name.TextSize = 14
	name.TextColor3 = Color3.fromRGB(255,255,255)
	name.TextXAlignment = Enum.TextXAlignment.Center
	name.Parent = tile

	-- Price
	local price = Instance.new("TextLabel")
	price.Name = "Price"
	price.Size = UDim2.new(1, -12, 0, 18)
	price.Position = UDim2.new(0, 6, 1, -22)
	price.BackgroundTransparency = 1
	price.Text = opts.PriceText or ""
	price.Font = Enum.Font.GothamBold
	price.TextSize = 14
	price.TextColor3 = Color3.fromRGB(220,220,220)
	price.TextXAlignment = Enum.TextXAlignment.Center
	price.Parent = tile

	-- Click highlight (visual)
	local button = Instance.new("TextButton")
	button.Name = "ClickLayer"
	button.Size = UDim2.new(1,0,1,0)
	button.BackgroundTransparency = 1
	button.Text = ""
	button.Parent = tile

	local selected = false
	button.MouseButton1Click:Connect(function()
		selected = not selected
		if selected then
			stroke.Color = Color3.fromRGB(0,255,200)
			stroke.Transparency = 0
		else
			stroke.Color = Color3.fromRGB(80,80,80)
			stroke.Transparency = 0.25
		end
	end)

	-- Make the tile movable (drag anywhere on the tile)
	makeDraggable(button, tile)

	return tile
end

